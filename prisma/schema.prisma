generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  id            String   @id @default(cuid())
  rollNumber    String   @unique
  name          String
  fatherName    String
  course        String
  dob           String
  contactNumber String
  photoUrl      String?
  createdAt     DateTime @default(now())
  results       Result[]
}

model Result {
  id            String  @id @default(cuid())
  studentId     String
  student       Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectName   String
  marksObtained Float
  maxMarks      Float
}

model Admin {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
}
